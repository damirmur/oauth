# Server
PORT=3000
NODE_ENV=development

# JWT Secret (change this in production!)
JWT_SECRET=super-secret-key-3d

# ==================== OAuth Credentials ====================
# Configure your OAuth provider credentials here

# Google OAuth
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and enable Google+ API
# 3. Create OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
# 1. Go to https://developers.facebook.com/
# 2. Create an app and add Facebook Login
# 3. Get App ID and App Secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# VKontakte OAuth
# 1. Go to https://vk.com/apps?act=manage
# 2. Create an application
# 3. Get App ID and Secure Key
VK_APP_ID=your-vk-app-id
VK_APP_SECRET=your-vk-app-secret

# Telegram Login Widget
# 1. Create a bot via @BotFather on Telegram
# 2. Use @userinfobot to get your bot username
# 3. Add the widget to your login page
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

