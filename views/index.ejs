<!-- views/index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome</title>
    <link rel="stylesheet" href="/stylesheets/main.css">
</head>
<body>
    <div class="header">
        <% if (user) { %>
            <div>Привет, <strong><%= profile && profile.name ? profile.name : user.email %></strong>!</div>
            <div>
                <a href="/me">Мой профиль</a>
                <a href="/auth/logout" onclick="event.preventDefault(); document.getElementById('logout-form').submit();">
                    Выйти
                </a>
                <form id="logout-form" action="/auth/logout" method="POST" class="hidden-form"></form>
            </div>
<% } else { %>
            <div>Гость</div>
            <div>
                <span class="disabled-link">Мой профиль</span>
                <a href="/register">Регистрация</a>
                <a href="/login">Войти</a>
            </div>
        <% } %>
    </div>

    <h1>Welcome to my website</h1>
    <p>Это главная страница. Вы можете войти или зарегистрироваться.</p>
    <%- include('partials/alerts') %>
</body>
</html>