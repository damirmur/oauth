<div id="toast-container" style="position: fixed; top: 20px; right: 20px; z-index: 10000; display: flex; flex-direction: column; gap: 10px;"></div>

<style>
    .custom-toast {
        position: relative;
        min-width: 280px;
        max-width: 400px;
        padding: 16px 45px 16px 20px; /* Отступ справа под крестик */
        border-radius: 12px;
        background: #ffffff;
        color: #333;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        font-family: -apple-system, system-ui, sans-serif;
        border-left: 6px solid #4CAF50;
        animation: toast-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        align-items: center;
        line-height: 1.4;
    }
    .custom-toast.error { border-left-color: #f44336; }

    /* Кнопка закрытия */
    .toast-close {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #999;
        font-size: 20px;
        cursor: pointer;
        padding: 5px;
        line-height: 1;
        transition: color 0.2s;
    }
    .toast-close:hover { color: #333; }

    @keyframes toast-in {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
</style>

<script>
    (function() {
        const container = document.getElementById('toast-container');

        function addToast(msg, type) {
            const div = document.createElement('div');
            div.className = 'custom-toast' + (type === 'error' ? ' error' : '');
            
            // Текст сообщения + кнопка-крестик
            div.innerHTML = `
                <span>${type === 'error' ? '❌' : '✅'} ${msg}</span>
                <button class="toast-close" onclick="this.parentElement.remove()">&times;</button>
            `;

            container.appendChild(div);

            // Авто-удаление через 5 секунд (чуть дольше, раз есть крестик)
            setTimeout(() => {
                if (div.parentNode) {
                    div.style.opacity = '0';
                    div.style.transform = 'translateX(20px)';
                    div.style.transition = 'all 0.4s ease';
                    setTimeout(() => div.remove(), 400);
                }
            }, 5000);
        }

        <% if (locals.flash_success && flash_success.length > 0) { %> 
            addToast("<%= flash_success %>", 'success'); 
        <% } %>
        <% if (locals.flash_error && flash_error.length > 0) { %> 
            addToast("<%= flash_error %>", 'error'); 
        <% } %>
    })();
</script>
