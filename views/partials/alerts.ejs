<div id="toast-container"></div>

<link rel="stylesheet" href="/stylesheets/toast.css">

<script>
    (function() {
        const container = document.getElementById('toast-container');
        const icons = { success: '✅', error: '❌', info: 'ℹ️' };

        function spawnToast(message, type = 'success') {
            if (!message || message.length === 0) return;

            const toast = document.createElement('div');
            toast.className = `modern-toast ${type}`;
            
            toast.innerHTML = `
                <span class="toast-icon">${icons[type]}</span>
                <div class="toast-content">${message}</div>
                <button class="toast-close" onclick="this.parentElement.remove()">&times;</button>
                <div class="toast-progress"></div>
            `;

            container.appendChild(toast);

            // Удаление через 4 секунды
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.style.transform = 'translateX(20px)';
                    toast.style.opacity = '0';
                    toast.style.transition = 'all 0.4s ease';
                    setTimeout(() => toast.remove(), 400);
                }
            }, 4000);
        }

        // Вызовы из Express Flash
        <% if (locals.flash_success && flash_success.length > 0) { %>
            spawnToast("<%= flash_success %>", 'success');
        <% } %>
        <% if (locals.flash_error && flash_error.length > 0) { %>
            spawnToast("<%= flash_error %>", 'error');
        <% } %>
        <% if (locals.flash_info && flash_info.length > 0) { %>
            spawnToast("<%= flash_info %>", 'info');
        <% } %>
    })();
</script>
