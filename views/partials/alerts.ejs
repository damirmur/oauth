<div id="toast-container" style="position: fixed; top: 20px; right: 20px; z-index: 10000; display: flex; flex-direction: column; gap: 12px;"></div>

<style>
    .modern-toast {
        position: relative;
        min-width: 300px;
        max-width: 450px;
        background: #ffffff;
        color: #2c3e50;
        padding: 16px 40px 16px 16px;
        border-radius: 12px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: 'Segoe UI', Roboto, sans-serif;
        animation: toast-slide-in 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        overflow: hidden;
    }

    /* Цветовые схемы */
    .modern-toast.success { border-left: 6px solid #00b894; }
    .modern-toast.error   { border-left: 6px solid #ff7675; }
    .modern-toast.info    { border-left: 6px solid #0984e3; }

    .toast-icon { font-size: 20px; }

    .toast-close {
        position: absolute;
        right: 8px;
        top: 8px;
        background: none;
        border: none;
        color: #b2bec3;
        font-size: 18px;
        cursor: pointer;
        transition: color 0.2s;
    }
    .toast-close:hover { color: #636e72; }

    /* Полоска времени */
    .toast-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 3px;
        width: 100%;
        background: rgba(0,0,0,0.05);
    }
    .toast-progress::after {
        content: '';
        display: block;
        height: 100%;
        width: 100%;
        animation: toast-progress-bar 4s linear forwards;
    }
    /* Цвет полоски совпадает с типом */
    .success .toast-progress::after { background: #00b894; }
    .error .toast-progress::after   { background: #ff7675; }
    .info .toast-progress::after    { background: #0984e3; }

    @keyframes toast-slide-in {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
    @keyframes toast-progress-bar {
        from { width: 100%; }
        to { width: 0%; }
    }
    /* Адаптивность для мобильных телефонов */
@media (max-width: 480px) {
    #toast-container {
        top: auto !important; /* Убираем привязку к верху */
        bottom: 20px;          /* Прижимаем к низу */
        right: 10px !important;
        left: 10px !important; /* Центрируем по бокам */
    }

    .modern-toast {
        min-width: auto;       /* Убираем фиксированную ширину */
        width: 100%;           /* Растягиваем на всю ширину экрана */
        max-width: none;
        margin-bottom: 8px;    /* Уменьшаем отступы между тостами */
        font-size: 14px;       /* Немного уменьшаем шрифт */
        padding: 12px 35px 12px 12px;
        box-shadow: 0 -5px 20px rgba(0,0,0,0.1); /* Тень падает вверх */
        animation: toast-slide-up 0.4s ease-out; /* Новая анимация для низа */
    }

    @keyframes toast-slide-up {
        from { transform: translateY(100px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
}

</style>

<script>
    (function() {
        const container = document.getElementById('toast-container');
        const icons = { success: '✅', error: '❌', info: 'ℹ️' };

        function spawnToast(message, type = 'success') {
            if (!message || message.length === 0) return;

            const toast = document.createElement('div');
            toast.className = `modern-toast ${type}`;
            
            toast.innerHTML = `
                <span class="toast-icon">${icons[type]}</span>
                <div class="toast-content">${message}</div>
                <button class="toast-close" onclick="this.parentElement.remove()">&times;</button>
                <div class="toast-progress"></div>
            `;

            container.appendChild(toast);

            // Удаление через 4 секунды
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.style.transform = 'translateX(20px)';
                    toast.style.opacity = '0';
                    toast.style.transition = 'all 0.4s ease';
                    setTimeout(() => toast.remove(), 400);
                }
            }, 4000);
        }

        // Вызовы из Express Flash
        <% if (locals.flash_success && flash_success.length > 0) { %>
            spawnToast("<%= flash_success %>", 'success');
        <% } %>
        <% if (locals.flash_error && flash_error.length > 0) { %>
            spawnToast("<%= flash_error %>", 'error');
        <% } %>
        <% if (locals.flash_info && flash_info.length > 0) { %>
            spawnToast("<%= flash_info %>", 'info');
        <% } %>
    })();
</script>
