<!-- views/login.ejs -->
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вход</title>
    <link rel="stylesheet" href="/stylesheets/login.css">
    <!-- Telegram Login Widget -->
    <script async src="https://telegram.org/js/telegram-widget.js?22" data-telegram-login="YOUR_BOT_NAME" data-size="medium" data-auth-url="/auth/telegram" data-request-access="write"></script>
</head>
<body>
    <div class="form-container">
        <h2>Вход</h2>
        
        <!-- OAuth Buttons -->
        <div class="oauth-buttons">
            <a href="/auth/google" class="oauth-btn google">
                <svg viewBox="0 0 24 24" width="20" height="20">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                Войти через Google
            </a>
            <a href="/auth/facebook" class="oauth-btn facebook">
                <svg viewBox="0 0 24 24" width="20" height="20">
                    <path fill="#1877F2" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Войти через Facebook
            </a>
            <a href="/auth/vk" class="oauth-btn vk">
                <svg viewBox="0 0 24 24" width="20" height="20">
                    <path fill="#0077FF" d="M15.684 0H8.316C1.592 0 0 1.592 0 8.316v7.368C0 22.408 1.592 24 8.316 24h7.368C22.408 24 24 22.408 24 15.684V8.316C24 1.592 22.408 0 15.684 0zm3.692 17.123h-1.744c-.66 0-.864-.525-2.05-1.723-1.053-1.053-.723-1.494 0-2.156.263-.263.385-.369.69-.369.165 0 .33.018.462.054.462.108.99.69.99 1.527 0 .84-.462 1.527-1.023 1.723-.378.132-.756.264-1.494.264-2.994 0-4.595-1.833-4.595-4.68 0-2.268 1.4-3.636 3.89-3.636 1.031 0 1.833.132 2.374.297v1.699c-.378-.108-.972-.216-1.608-.216-1.103 0-1.685.378-1.685 1.053 0 .756.615 1.071 1.703 1.071.99 0 1.889-.33 2.592-.99.756-.756.924-1.169 1.397-1.169.297 0 .54.165.702.495.513 1.031.66 1.869.66 2.736 0 .495-.165.957-.513 1.377-.297.378-.756.495-1.167.495z"/>
                </svg>
                Войти через VK
            </a>
        </div>
        
        <div class="divider"><span>или</span></div>
        
        <form action="/auth/login" method="post">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="Введите email" required />
            </div>
            <div class="form-group">
                <label for="password">Пароль</label>
                <input type="password" id="password" name="password" placeholder="Введите пароль" required />
            </div>
            <div class="form-actions">
                <button type="submit">Войти</button>
            </div>
        </form>
        <div class="extra-links">
            <a href="/forgot-password">Забыли пароль?</a><br>
            <a href="/register">Нет аккаунта? Зарегистрироваться</a>
        </div>
    </div>
    <%- include('partials/alerts') %>
</body>

</html>
