<!-- views/forgot-password.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Сброс пароля</title>
    <link rel="stylesheet" href="/stylesheets/forgot-password.css">
</head>
<body>
    <div class="form-container">
        <h2>Сброс пароля</h2>
        <p>Введите email, на который вы регистрировались. Мы отправим ссылку для восстановления.</p>
        <form action="/auth/forgot-password" method="post">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="Введите email" required />
            </div>
            <div class="form-actions">
                <button type="submit">Отправить ссылку</button>
            </div>
        </form>
        <div class="extra-links">
            <a href="/login">← Назад ко входу</a>
        </div>
    </div>
    <%- include('partials/alerts') %>q
</body>
</html>